COMPOSE_PROJECT_NAME=vm2026

# MySQL — gere senhas novas e fortes para produção (nunca reaproveite as de dev)
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=vm2026
MYSQL_USER=vm2026
MYSQL_PASSWORD=

# Domínio público da aplicação (detectado automaticamente pelo nginx-proxy/acme-companion
# já existente na VPS via VIRTUAL_HOST/LETSENCRYPT_HOST — ver docker-compose.prod.yml)
DOMINIO=vm2026.avideomart.com.br

# Domínio "base" sem o prefixo do app — usado para montar o subdomínio do phpMyAdmin
# (ex.: phpmyadmin-vm2026.avideomart.com.br)
DOMINIO_BASE=avideomart.com.br

# Autenticação (backend) — gere com: openssl rand -hex 32
JWT_SECRET=

# Usuário admin inicial (gerado via "docker compose -f docker-compose.prod.yml exec backend npm run seed:admin")
ADMIN_NOME=Administrador
ADMIN_EMAIL=
ADMIN_PASSWORD=

# SMTP para envio de e-mails (proposta individual / fallback de campanhas sem
# contas_smtp cadastradas — ver tela Configurações > Contas SMTP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
FRONTEND_URL=https://vm2026.avideomart.com.br
