COMPOSE_PROJECT_NAME=vm2026

# MySQL
MYSQL_ROOT_PASSWORD=troque_esta_senha
MYSQL_DATABASE=vm2026
MYSQL_USER=vm2026
MYSQL_PASSWORD=troque_esta_senha

# Portas expostas no host (diferentes do vm2025 para evitar conflito)
FRONTEND_PORT=8082
BACKEND_PORT=8083
DB_PORT=3307

# Autenticação (backend) — gere um valor aleatório, ex.: openssl rand -hex 32
JWT_SECRET=troque_este_segredo

# Usuário admin inicial (gerado via "docker compose exec backend npm run seed:admin")
ADMIN_NOME=Administrador
ADMIN_EMAIL=admin@videomart.com.br
ADMIN_PASSWORD=troque_esta_senha

# SMTP (envio de propostas/e-mails e redefinição de senha)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="VideoMart <nao-responda@videomart.com.br>"

# URL pública do frontend (usada em links de e-mail, ex.: redefinição de senha)
FRONTEND_URL=https://vm2026.avideomart.com.br

# Domínio usado pelo nginx-proxy/letsencrypt em produção
DOMINIO=vm2026.avideomart.com.br
DOMINIO_BASE=avideomart.com.br
